<UserControl x:Class="Diplom.StudentEditView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Diplom"
             mc:Ignorable="d" d:DesignWidth="600" Height="697">

    <UserControl.Resources>
        <!-- Стиль для меток полей -->
        <Style x:Key="FormLabel" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="#333"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <!-- Стиль для TextBox с placeholder -->
        <Style x:Key="FormTextBox" TargetType="TextBox">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Grid>
                            <Border Background="White" 
                                    BorderBrush="{TemplateBinding BorderBrush}" 
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6">
                                <Grid>
                                    <ScrollViewer x:Name="PART_ContentHost" 
                                                  Margin="14,0,14,0"
                                                  VerticalAlignment="Center"/>
                                    <TextBlock Text="{TemplateBinding Tag}" 
                                               Foreground="#999" 
                                               FontSize="14"
                                               Margin="14,0,14,0"
                                               VerticalAlignment="Center"
                                               IsHitTestVisible="False"
                                               x:Name="PlaceholderText"
                                               Visibility="Collapsed"/>
                                </Grid>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="PlaceholderText" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="Text" Value="{x:Null}">
                                <Setter TargetName="PlaceholderText" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#5271FF"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsFocused" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="PlaceholderText" Property="Visibility" Value="Collapsed"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FormComboBox" TargetType="ComboBox">
            <Setter Property="Margin" Value="0,0,0,16"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable"/>
            <Setter Property="BorderBrush" Value="#E0E3E7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#1A1C1E"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <!-- Основной контейнер ComboBox -->
                            <ToggleButton x:Name="ToggleButton"
                                  Background="{TemplateBinding Background}"
                                  BorderBrush="{TemplateBinding BorderBrush}"
                                  BorderThickness="{TemplateBinding BorderThickness}"
                                  IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                  Focusable="False">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Border" 
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="8">
                                            <Grid>
                                                <!-- Стрелка вниз -->
                                                <Path x:Name="Arrow"
                                              Width="10"
                                              Height="6"
                                              Fill="#1A1C1E"
                                              Stretch="Uniform"
                                              HorizontalAlignment="Right"
                                              VerticalAlignment="Center"
                                              Margin="0,0,12,0"
                                              Data="M0,0 L1,0 0.5,1 Z"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Border" Property="BorderBrush" Value="#A0A5AB"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="Border" Property="Background" Value="#E0E3E7"/>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter TargetName="Border" Property="Background" Value="#F0F0F0"/>
                                                <Setter TargetName="Border" Property="BorderBrush" Value="#D0D0D0"/>
                                                <Setter TargetName="Arrow" Property="Fill" Value="#D0D0D0"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <!-- Поле вывода выбранного значения -->
                            <ContentPresenter x:Name="ContentSite"
                                      Content="{TemplateBinding SelectionBoxItem}"
                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                      ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                      Margin="{TemplateBinding Padding}"
                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                      IsHitTestVisible="False"/>

                            <!-- Стрелка вниз -->
                            <Path x:Name="Arrow"
                          Width="10"
                          Height="6"
                          Fill="#1A1C1E"
                          Stretch="Uniform"
                          HorizontalAlignment="Right"
                          VerticalAlignment="Center"
                          Margin="0,0,12,0"
                          Data="M0,0 L1,0 0.5,1 Z"/>

                            <!-- Выпадающий список -->
                            <Popup x:Name="PART_Popup"
                           Placement="Bottom"
                           IsOpen="{TemplateBinding IsDropDownOpen}"
                           AllowsTransparency="True"
                           Focusable="False"
                           PopupAnimation="Slide">
                                <Border Background="#FFFFFF"
                                BorderBrush="#E0E3E7"
                                BorderThickness="1"
                                CornerRadius="8">
                                    <ScrollViewer>
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>

                            <!-- Обводка при фокусе -->
                            <Border x:Name="focusOverlay"
                            CornerRadius="8"
                            BorderThickness="2"
                            BorderBrush="#2B5FF0"
                            Opacity="0"
                            IsHitTestVisible="False"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ToggleButton" Property="BorderBrush" Value="#A0A5AB"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="focusOverlay" Property="Opacity" Value="1"/>
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="Arrow" Property="Fill" Value="#2B5FF0"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ToggleButton" Property="Background" Value="#F0F0F0"/>
                                <Setter TargetName="ToggleButton" Property="BorderBrush" Value="#D0D0D0"/>
                                <Setter TargetName="Arrow" Property="Fill" Value="#D0D0D0"/>
                                <Setter Property="Foreground" Value="#A0A0A0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>

            <!-- Стиль для элементов внутри выпадающего списка -->
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Padding" Value="8,6"/>
                        <Setter Property="FontSize" Value="14"/>
                        <Setter Property="FontFamily" Value="Segoe UI Variable"/>
                        <Setter Property="Background" Value="#FFFFFF"/>
                        <Setter Property="Foreground" Value="#1A1C1E"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="itemBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="#E0E3E7"
                                    BorderThickness="0,0,0,1"
                                    Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="itemBorder" Property="Background" Value="#F0F3F7"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="itemBorder" Property="Background" Value="#E0E3E7"/>
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter TargetName="itemBorder" Property="Background" Value="#F0F0F0"/>
                                            <Setter Property="Foreground" Value="#A0A0A0"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Шаблон для кнопки-триггера ComboBox -->
        <ControlTemplate x:Key="ComboBoxToggleButtonTemplate" TargetType="ToggleButton">
            <Border x:Name="Border" 
            Background="{TemplateBinding Background}"
            BorderBrush="{TemplateBinding BorderBrush}"
            BorderThickness="{TemplateBinding BorderThickness}"
            CornerRadius="8">
                <Grid>
                    <Path x:Name="Arrow"
                  Width="10"
                  Height="6"
                  Fill="#1A1C1E"
                  Stretch="Uniform"
                  HorizontalAlignment="Right"
                  VerticalAlignment="Center"
                  Margin="0,0,12,0"
                  Data="M0,0 L1,0 0.5,1 Z"/>
                </Grid>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Border" Property="BorderBrush" Value="#A0A5AB"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter TargetName="Border" Property="Background" Value="#E0E3E7"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter TargetName="Border" Property="Background" Value="#F0F0F0"/>
                    <Setter TargetName="Border" Property="BorderBrush" Value="#D0D0D0"/>
                    <Setter TargetName="Arrow" Property="Fill" Value="#D0D0D0"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <!-- Стиль для DatePicker -->
        <Style x:Key="FormDatePicker" TargetType="DatePicker">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <!-- Стиль для основной кнопки -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="30,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="#5271FF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="6" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4060E8"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для вторичной кнопки -->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="30,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#666"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F8F9FA"/>
                    <Setter Property="BorderBrush" Value="#5271FF"/>
                    <Setter Property="Foreground" Value="#5271FF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для текстовой кнопки -->
        <Style x:Key="TextButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#5271FF"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F5F7FF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для маленькой кнопки добавления -->
        <Style x:Key="AddButton" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#5271FF"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#5271FF"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F5F7FF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Background="#F8F9FA">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="30,20">
            <Grid>
                <StackPanel Orientation="Horizontal">
                    <Button Content="←" 
                            Style="{StaticResource TextButton}"
                            Click="BackButton_Click"
                            Margin="0,0,10,0"
                            Padding="8" FontSize="22" FontWeight="Bold"/>
                    <StackPanel>
                        <TextBlock x:Name="TitleText" 
                                   Text="Добавление студента" 
                                   FontSize="22" 
                                   FontWeight="SemiBold" 
                                   Foreground="#333"/>
                        <TextBlock Text="Заполните информацию о студенте" 
                                   FontSize="13" 
                                   Foreground="#999"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Форма -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Border Background="White" 
                    BorderBrush="#E0E0E0" 
                    BorderThickness="1"
                    CornerRadius="8"
                    Margin="30,20,30,20"
                    Padding="30">
                <StackPanel Orientation="Vertical" MaxWidth="600">

                    <!-- Основная информация -->
                    <TextBlock Text="📝 Основная информация" 
                               FontSize="16" 
                               FontWeight="SemiBold" 
                               Foreground="#333"
                               Margin="0,0,0,20"/>

                    <!-- ФИО -->
                    <StackPanel Margin="0,0,0,20">
                        <TextBlock Style="{StaticResource FormLabel}">
                            <Run Text="ФИО"/>
                            <Run Text="*" Foreground="#E53E3E"/>
                        </TextBlock>
                        <TextBox x:Name="FullNameTextBox" 
                                 Style="{StaticResource FormTextBox}"
                                 Tag="Введите полное имя студента"
                                 Text="{Binding Student.FullName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <!-- Дата рождения -->
                    <StackPanel Margin="0,0,0,20">
                        <TextBlock Text="Дата рождения" Style="{StaticResource FormLabel}"/>
                        <DatePicker x:Name="BirthDatePicker" 
                                    Style="{StaticResource FormDatePicker}"
                                    SelectedDate="{Binding Student.BirthDate, Mode=TwoWay}"/>
                    </StackPanel>

                    <!-- Группа -->
                    <StackPanel Margin="0,0,0,20">
                        <TextBlock Text="Группа" Style="{StaticResource FormLabel}"/>
                        <ComboBox x:Name="ClassComboBox"
                                   Style="{StaticResource FormComboBox}"
                                   DisplayMemberPath="Name"  
                                   SelectedValuePath="Id"
                                   SelectedValue="{Binding Student.ClassId, Mode=TwoWay}" Height="42">
                        </ComboBox>
                        <TextBlock Text="Выберите группу из списка" 
                                   FontSize="12" 
                                   Foreground="#999"
                                   Margin="0,6,0,0"/>
                    </StackPanel>

                    <!-- Контакты -->
                    <StackPanel Margin="0,0,0,30">

                        <TextBlock Text="Контактная информация" Style="{StaticResource FormLabel}"/>
                        <TextBox x:Name="ContactTextBox" 
                                 Style="{StaticResource FormTextBox}"
                                 Tag="Телефон или email"
                                 Text="{Binding Student.Contact, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" TextChanged="ContactTextBox_TextChanged_1"/>
                        <TextBlock Text="Телефон или email для связи со студентом" 
                                   FontSize="12" 
                                   Foreground="#999"
                                   Margin="0,6,0,0"/>
                    </StackPanel>

                    <!-- Разделитель -->
                    <Border Height="1" Background="#E0E0E0" Margin="0,10,0,20"/>

                    <!-- Родители -->
                    <StackPanel>
                        <Grid Margin="0,0,0,15">
                            <TextBlock Text="👨‍👩‍👧‍👦 Родители и опекуны" 
                                       FontSize="16" 
                                       FontWeight="SemiBold" 
                                       Foreground="#333"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="➕ Выбрать из списка" 
                                        Style="{StaticResource AddButton}"
                                        Click="SelectExistingParent_Click"
                                        Margin="0,0,8,0"/>
                                <Button Content="➕ Создать нового" 
                                        Style="{StaticResource PrimaryButton}"
                                        Click="AddParentButton_Click"
                                        Background="#5271FF"
                                        Foreground="White"/>
                            </StackPanel>
                        </Grid>

                        <Border Background="#F8F9FA" 
                                BorderBrush="#E0E0E0" 
                                BorderThickness="1" 
                                Padding="20" 
                                CornerRadius="8"
                                MinHeight="100">
                            <StackPanel>
                                <ItemsControl x:Name="ParentsItemsControl">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="White" 
                                                    BorderBrush="#E0E0E0" 
                                                    BorderThickness="1" 
                                                    Padding="15" 
                                                    Margin="0,0,0,10" 
                                                    CornerRadius="6">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <!-- Иконка -->
                                                    <Border Grid.Column="0" 
                                                            Width="45" 
                                                            Height="45" 
                                                            Background="#F5F7FF"
                                                            CornerRadius="6"
                                                            Margin="0,0,15,0">
                                                        <TextBlock Text="👤" 
                                                                   FontSize="20" 
                                                                   HorizontalAlignment="Center" 
                                                                   VerticalAlignment="Center"/>
                                                    </Border>

                                                    <!-- Информация -->
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding FullName}" 
                                                                   FontWeight="SemiBold" 
                                                                   FontSize="14"
                                                                   Foreground="#333"/>
                                                        <TextBlock x:Name="PhoneText" 
                                                                   Text="{Binding Phone}" 
                                                                   FontSize="12" 
                                                                   Foreground="#666"
                                                                   Margin="0,2,0,0"/>
                                                        <TextBlock x:Name="EmailText" 
                                                                   Text="{Binding Email}" 
                                                                   FontSize="12" 
                                                                   Foreground="#666"
                                                                   Margin="0,2,0,0"/>
                                                    </StackPanel>

                                                    <!-- Кнопка редактирования -->
                                                    <Button Grid.Column="2" 
                                                            Content="✏️" 
                                                            Background="Transparent" 
                                                            BorderThickness="0"
                                                            Foreground="#5271FF"
                                                            FontSize="16"
                                                            Width="35"
                                                            Height="35"
                                                            Cursor="Hand"
                                                            Click="EditParent_Click"
                                                            Tag="{Binding}"
                                                            ToolTip="Редактировать">
                                                        <Button.Style>
                                                            <Style TargetType="Button">
                                                                <Setter Property="Template">
                                                                    <Setter.Value>
                                                                        <ControlTemplate TargetType="Button">
                                                                            <Border Background="{TemplateBinding Background}" 
                                                                                    CornerRadius="6"
                                                                                    Padding="5">
                                                                                <ContentPresenter HorizontalAlignment="Center" 
                                                                                                  VerticalAlignment="Center"/>
                                                                            </Border>
                                                                        </ControlTemplate>
                                                                    </Setter.Value>
                                                                </Setter>
                                                                <Style.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="Background" Value="#F0F4FF"/>
                                                                    </Trigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                    </Button>

                                                    <!-- Кнопка удаления -->
                                                    <Button Grid.Column="3" 
                                                            Content="🗑️" 
                                                            Background="Transparent" 
                                                            BorderThickness="0"
                                                            Foreground="#E53E3E"
                                                            FontSize="16"
                                                            Width="35"
                                                            Height="35"
                                                            Cursor="Hand"
                                                            Click="RemoveParent_Click"
                                                            Tag="{Binding}"
                                                            ToolTip="Удалить">
                                                        <Button.Style>
                                                            <Style TargetType="Button">
                                                                <Setter Property="Template">
                                                                    <Setter.Value>
                                                                        <ControlTemplate TargetType="Button">
                                                                            <Border Background="{TemplateBinding Background}" 
                                                                                    CornerRadius="6"
                                                                                    Padding="5">
                                                                                <ContentPresenter HorizontalAlignment="Center" 
                                                                                                  VerticalAlignment="Center"/>
                                                                            </Border>
                                                                        </ControlTemplate>
                                                                    </Setter.Value>
                                                                </Setter>
                                                                <Style.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="Background" Value="#FFF5F5"/>
                                                                    </Trigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                    </Button>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- Заглушка, если нет родителей -->
                                <TextBlock x:Name="EmptyParentsText" 
                                           Text="Нет добавленных родителей. Нажмите 'Создать нового' или 'Выбрать из списка'" 
                                           FontSize="12" 
                                           Foreground="#999"
                                           HorizontalAlignment="Center"
                                           Margin="0,10,0,10"
                                           Visibility="Collapsed"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="ℹ️ Вы можете добавить нескольких родителей для студента" 
                                   FontSize="12" 
                                   Foreground="#999"
                                   Margin="0,10,0,0"/>
                    </StackPanel>

                </StackPanel>
            </Border>
        </ScrollViewer>

        <!-- Кнопки действий -->
        <Border Grid.Row="2" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Padding="30,15">
            <Grid>
                <TextBlock Text="* Обязательные поля" 
                           FontSize="12" 
                           Foreground="#999"
                           VerticalAlignment="Center"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Отмена" 
                            Style="{StaticResource SecondaryButton}"
                            Click="CancelButton_Click"
                            Margin="0,0,10,0"/>

                    <Button x:Name="SaveButton"
                            Content="💾 Сохранить" 
                            Style="{StaticResource PrimaryButton}"
                            Click="SaveButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</UserControl>