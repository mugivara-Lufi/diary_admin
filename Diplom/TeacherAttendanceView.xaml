<UserControl x:Class="Diplom.TeacherAttendanceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1200"
             Background="#F8F9FA">

    <UserControl.Resources>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Background" Value="#5271FF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4060E8"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#666"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F8F9FA"/>
                    <Setter Property="BorderBrush" Value="#5271FF"/>
                    <Setter Property="Foreground" Value="#5271FF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FormComboBox" TargetType="ComboBox">
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="FormDatePicker" TargetType="DatePicker">
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#F8F9FA"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#F0F0F0"/>
            <Setter Property="VerticalGridLinesBrush" Value="Transparent"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F8F9FA"/>
            <Setter Property="Foreground" Value="#333"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Height" Value="40"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Шапка -->
        <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="30,20">
            <Grid>
                <StackPanel>
                    <TextBlock Text="✅ Учет посещаемости" FontSize="22" FontWeight="SemiBold" Foreground="#333"/>
                    <TextBlock Text="Отметка присутствия студентов на занятиях" FontSize="13" Foreground="#999" Margin="0,5,0,0"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Border Background="#F5F7FF" Padding="12,8" CornerRadius="6">
                        <TextBlock x:Name="CurrentDateText" FontSize="13" Foreground="#5271FF"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Основной контент -->
        <Grid Grid.Row="1" Margin="30,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Панель фильтров -->
            <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" Padding="20" Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Группа -->
                    <StackPanel Grid.Column="0" Margin="0,0,15,0">
                        <TextBlock Text="Группа" FontSize="12" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,6"/>
                        <ComboBox x:Name="GroupComboBox" Style="{StaticResource FormComboBox}" 
                                  DisplayMemberPath="Name" SelectedValuePath="Id"
                                  SelectionChanged="GroupComboBox_SelectionChanged"/>
                    </StackPanel>

                    <!-- Дисциплина -->
                    <StackPanel Grid.Column="1" Margin="0,0,15,0">
                        <TextBlock Text="Дисциплина" FontSize="12" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,6"/>
                        <ComboBox x:Name="SubjectComboBox" Style="{StaticResource FormComboBox}" 
                                  DisplayMemberPath="Name" SelectedValuePath="Id"
                                  SelectionChanged="SubjectComboBox_SelectionChanged" IsEnabled="False"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="0,0,15,0">
                        <TextBlock Text="Дата занятия" FontSize="12" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,6"/>
                        <ComboBox x:Name="DatePickerComboBox" Style="{StaticResource FormComboBox}" 
                        IsEnabled="False" SelectionChanged="DatePickerComboBox_SelectionChanged"/>
                    </StackPanel>

                    <!-- Кнопки -->
                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Bottom">
                        <Button Content="✔️ Все присутствуют" Style="{StaticResource SecondaryButton}" 
                                Click="MarkAllPresent_Click" Margin="0,0,10,0"/>
                        <Button Content="❌ Все отсутствуют" Style="{StaticResource SecondaryButton}" 
                                Click="MarkAllAbsent_Click" Margin="0,0,10,0"/>
                        <Button x:Name="SaveButton" Content="💾 Сохранить" Style="{StaticResource PrimaryButton}" 
                                Click="SaveAttendance_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
            <Border x:Name="CanEditWarning" Grid.Row="1" Background="#FEF2F2" BorderBrush="#FEE2E2" 
        BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,10,0,0" Visibility="Collapsed">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="⚠️" FontSize="16" Margin="0,0,10,0"/>
                    <TextBlock Text="Редактирование оценок за прошедшие даты возможно, но изменения могут повлиять на статистику."
                   FontSize="12" Foreground="#DC2626" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
            <!-- Таблица студентов -->
            <Border Grid.Row="1" Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#F8F9FA" Padding="15,12" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
                        <TextBlock Text="👥 Список студентов" FontSize="15" FontWeight="SemiBold" Foreground="#333"/>
                    </Border>

                    <DataGrid x:Name="AttendanceGrid" Grid.Row="1" AutoGenerateColumns="False" 
                              CanUserAddRows="False" HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="№" Width="50" Binding="{Binding Number}">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="Foreground" Value="#999"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="ФИО студента" Width="250" Binding="{Binding StudentName}">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTemplateColumn Header="Присутствие" Width="120">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <RadioButton GroupName="Attendance" IsChecked="{Binding IsPresent}" 
                                                         Content="✅" Margin="5,0" Tag="present"
                                                         Checked="AttendanceRadio_Checked"/>
                                            <RadioButton GroupName="Attendance" IsChecked="{Binding IsAbsent}" 
                                                         Content="❌" Margin="5,0" Tag="absent"
                                                         Foreground="#E53E3E"
                                                         Checked="AttendanceRadio_Checked"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Комментарий" Width="*" Binding="{Binding Comment}">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#999"/>
                                        <Setter Property="FontStyle" Value="Italic"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Border Grid.Row="2" Background="#F8F9FA" Padding="15,10" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
                        <Grid>
                            <TextBlock x:Name="StatisticsText" FontSize="12" Foreground="#666" VerticalAlignment="Center"/>
                            <TextBlock x:Name="StatusText" FontSize="12" Foreground="#5271FF" HorizontalAlignment="Right"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>