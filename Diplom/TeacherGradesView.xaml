<UserControl x:Class="Diplom.TeacherGradesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Diplom"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="1000">

    <UserControl.Resources>
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowHeight" Value="52"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#F0F2F5"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="CanUserReorderColumns" Value="False"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="Cell"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#8F9BBA"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="12,16"/>
            <Setter Property="BorderBrush" Value="#E2E6EE"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridColumnHeader">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FAFBFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="Foreground" Value="#2B3674"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border x:Name="CellBorder" 
                                Background="Transparent" 
                                CornerRadius="8"
                                Margin="4,4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" 
                                              HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="CellBorder" Property="Background" Value="#EEF2FF"/>
                                <Setter Property="Foreground" Value="#4318FF"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="CellBorder" Property="BorderBrush" Value="#4318FF"/>
                                <Setter TargetName="CellBorder" Property="BorderThickness" Value="1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GradeEditTextBox" TargetType="TextBox">
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#4318FF"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="MaxLength" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Direction="270" Color="#4318FF" Opacity="0.15"/>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Стили кнопок (наследуем твою стилистику) -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="#5271FF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="6" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4060E8"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#666"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F8F9FA"/>
                    <Setter Property="BorderBrush" Value="#5271FF"/>
                    <Setter Property="Foreground" Value="#5271FF"/>
                </Trigger>
            </Style.Triggers>
        </Style>



        <!-- Конвертер цвета для оценки -->
        <local:GradeColorConverter x:Key="GradeColorConverter"/>

        <!-- Шаблон ячейки для просмотра -->
        <DataTemplate x:Key="GradeViewTemplate">
            <Border CornerRadius="4" 
                    Background="{Binding Path=Content.Text, 
                                RelativeSource={RelativeSource AncestorType=DataGridCell},
                                Converter={StaticResource GradeColorConverter},
                                ConverterParameter=background}"
                    Width="36" Height="30">
                <TextBlock Text="{Binding}" 
                           FontWeight="SemiBold" 
                           FontSize="14"
                           Foreground="{Binding Converter={StaticResource GradeColorConverter},
                                              ConverterParameter=foreground}"
                           HorizontalAlignment="Center" 
                           VerticalAlignment="Center"/>
            </Border>
        </DataTemplate>

        <!-- Шаблон ячейки с оценкой (средний балл) -->
        <DataTemplate x:Key="AverageTemplate">
            <Border CornerRadius="12" 
                    Background="#5271FF"
                    Padding="8,4"
                    MinWidth="44">
                <TextBlock Text="{Binding}" 
                           FontWeight="Bold" 
                           FontSize="15"
                           Foreground="White"
                           HorizontalAlignment="Center" 
                           VerticalAlignment="Center"/>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Background="#F8F9FA">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Панель управления -->
        <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0" 
                BorderThickness="0,0,0,1" Padding="30,20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Заголовок и фильтры -->
                <Grid Grid.Row="0" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="📊 Журнал оценок" 
                                   FontSize="22" 
                                   FontWeight="SemiBold" 
                                   Foreground="#333"/>
                        <TextBlock Text="Учебный журнал с оценками и посещаемостью" 
                                   FontSize="13" 
                                   Foreground="#999"
                                   Margin="0,5,0,0"/>
                    </StackPanel>

                    <!-- Фильтры справа -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBlock Text="Группа:" 
                                   FontSize="13" 
                                   Foreground="#666" 
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                        <ComboBox x:Name="ClassFilter" 
                                  Width="120" 
                                  Height="38"
                                  FontSize="13"
                                  Style="{StaticResource FormComboBox}"
                                  SelectionChanged="ClassFilter_SelectionChanged" Margin="0,0,0,0">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <TextBlock Text="Дисциплина:" 
                                   FontSize="13" 
                                   Foreground="#666" 
                                   VerticalAlignment="Center"
                                   Margin="20,0,8,0"/>
                        <ComboBox x:Name="SubjectFilter" 
                                  Width="160" 
                                  Height="38"
                                  FontSize="13"
                                  Style="{StaticResource FormComboBox}"
                                  SelectionChanged="SubjectFilter_SelectionChanged" Margin="0,0,0,0">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>
                </Grid>

                <!-- Кнопки действий -->
                <StackPanel Grid.Row="1" Orientation="Horizontal">
                    <Button  x:Name="SaveButton"
                            Content="💾 Сохранить изменения" 
                            Style="{StaticResource PrimaryButton}" 
                            Click="SaveChanges_Click"/>
                    <Button Content="🔄 Обновить" 
                            Style="{StaticResource SecondaryButton}" 
                            Click="Refresh_Click" 
                            Margin="10,0,0,0"/>


                    <!-- Легенда -->
                    <StackPanel Orientation="Horizontal" 
                                HorizontalAlignment="Right"
                                Margin="30,0,0,0">
                        <Border Background="#E8F5E9" CornerRadius="4" 
                                Padding="8,4" Margin="0,0,8,0">
                            <TextBlock Text="5" FontWeight="SemiBold" 
                                       Foreground="#2E7D32" FontSize="14" Height="15"/>
                        </Border>
                        <Border Background="#FFF3E0" CornerRadius="4" 
                                Padding="8,4" Margin="0,0,8,0">
                            <TextBlock Text="4" FontWeight="SemiBold" 
                                       Foreground="#E65100" FontSize="14" Height="15"/>
                        </Border>
                        <Border Background="#FFF8E1" CornerRadius="4" 
                                Padding="8,4" Margin="0,0,8,0">
                            <TextBlock Text="3" FontWeight="SemiBold" 
                                       Foreground="#F9A825" FontSize="14" Height="15"/>
                        </Border>
                        <Border Background="#FFEBEE" CornerRadius="4" 
                                Padding="8,4" Margin="0,0,8,0">
                            <TextBlock Text="2" FontWeight="SemiBold" 
                                       Foreground="#C62828" FontSize="14" Height="15"/>
                        </Border>
                        <Border Background="#F3E5F5" CornerRadius="4" Padding="8,4">
                            <TextBlock Text="Н" FontWeight="SemiBold" 
                                       Foreground="#7B1FA2" FontSize="14" Height="15"/>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Таблица-журнал -->
        <Border Grid.Row="1" 
                Background="White" 
                BorderBrush="#E0E0E0" 
                BorderThickness="1"
                CornerRadius="8"
                Margin="30,20,30,20">
            <DataGrid x:Name="GradesGrid"
                      AutoGenerateColumns="False"
                      FrozenColumnCount="1"
                      PreparingCellForEdit="GradesGrid_PreparingCellForEdit"
                      CellEditEnding="GradesGrid_CellEditEnding"
                      BeginningEdit="GradesGrid_BeginningEdit">
                <!-- Колонки генерируются динамически в code-behind -->
            </DataGrid>
        </Border>

        <!-- Статус бар -->
        <Border Grid.Row="2" Background="White" 
                BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" 
                Padding="30,12">
            <Grid>
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="StatusText" 
                               Text="Готово к работе" 
                               FontSize="12" 
                               Foreground="#666"
                               VerticalAlignment="Center"/>
                    <TextBlock Text=" • " 
                               FontSize="12" 
                               Foreground="#CCC"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="ChangesText" 
                               Text="Нет несохраненных изменений" 
                               FontSize="12" 
                               Foreground="#999"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock Text="Последнее обновление: " 
                               FontSize="12" 
                               Foreground="#999"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="LastUpdateText" 
                               Text="только что" 
                               FontSize="12" 
                               Foreground="#5271FF"
                               FontWeight="Medium"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>