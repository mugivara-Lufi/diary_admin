<UserControl x:Class="Diplom.ScheduleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Diplom"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="900">

    <UserControl.Resources>
        <!-- Стиль для основной кнопки -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="#5271FF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="6" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4060E8"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для вторичной кнопки -->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#666"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F8F9FA"/>
                    <Setter Property="BorderBrush" Value="#5271FF"/>
                    <Setter Property="Foreground" Value="#5271FF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для заголовков дней недели -->
        <Style x:Key="DayHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#333"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Стиль для времени -->
        <Style x:Key="TimeStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#999"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
            <Setter Property="Margin" Value="0,5,10,0"/>
        </Style>

        <!-- Стиль для ячеек расписания -->
        <Style x:Key="ScheduleCellStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F5F7FF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для карточки урока -->
        <Style x:Key="LessonCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#EEF2FF"/>
            <Setter Property="BorderBrush" Value="#5271FF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <!-- Стиль для выделенной карточки урока -->
        <Style x:Key="SelectedLessonCardStyle" TargetType="Border" BasedOn="{StaticResource LessonCardStyle}">
            <Setter Property="Background" Value="#D6E4FF"/>
            <Setter Property="BorderBrush" Value="#3366FF"/>
            <Setter Property="BorderThickness" Value="2"/>
        </Style>


        <Style x:Key="FormComboBox" TargetType="ComboBox">
            <Setter Property="Margin" Value="0,0,0,16"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable"/>
            <Setter Property="BorderBrush" Value="#E0E3E7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#1A1C1E"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <!-- Основной контейнер ComboBox -->
                            <ToggleButton x:Name="ToggleButton"
                                  Background="{TemplateBinding Background}"
                                  BorderBrush="{TemplateBinding BorderBrush}"
                                  BorderThickness="{TemplateBinding BorderThickness}"
                                  IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                  Focusable="False">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Border" 
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="8">
                                            <Grid>
                                                <!-- Стрелка вниз -->
                                                <Path x:Name="Arrow"
                                              Width="10"
                                              Height="6"
                                              Fill="#1A1C1E"
                                              Stretch="Uniform"
                                              HorizontalAlignment="Right"
                                              VerticalAlignment="Center"
                                              Margin="0,0,12,0"
                                              Data="M0,0 L1,0 0.5,1 Z"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Border" Property="BorderBrush" Value="#A0A5AB"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="Border" Property="Background" Value="#E0E3E7"/>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter TargetName="Border" Property="Background" Value="#F0F0F0"/>
                                                <Setter TargetName="Border" Property="BorderBrush" Value="#D0D0D0"/>
                                                <Setter TargetName="Arrow" Property="Fill" Value="#D0D0D0"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <!-- Поле вывода выбранного значения -->
                            <ContentPresenter x:Name="ContentSite"
                                      Content="{TemplateBinding SelectionBoxItem}"
                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                      ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                      Margin="{TemplateBinding Padding}"
                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                      IsHitTestVisible="False"/>

                            <!-- Стрелка вниз -->
                            <Path x:Name="Arrow"
                          Width="10"
                          Height="6"
                          Fill="#1A1C1E"
                          Stretch="Uniform"
                          HorizontalAlignment="Right"
                          VerticalAlignment="Center"
                          Margin="0,0,12,0"
                          Data="M0,0 L1,0 0.5,1 Z"/>

                            <!-- Выпадающий список -->
                            <Popup x:Name="PART_Popup"
                           Placement="Bottom"
                           IsOpen="{TemplateBinding IsDropDownOpen}"
                           AllowsTransparency="True"
                           Focusable="False"
                           PopupAnimation="Slide">
                                <Border Background="#FFFFFF"
                                BorderBrush="#E0E3E7"
                                BorderThickness="1"
                                CornerRadius="8">
                                    <ScrollViewer>
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>

                            <!-- Обводка при фокусе -->
                            <Border x:Name="focusOverlay"
                            CornerRadius="8"
                            BorderThickness="2"
                            BorderBrush="#2B5FF0"
                            Opacity="0"
                            IsHitTestVisible="False"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ToggleButton" Property="BorderBrush" Value="#A0A5AB"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="focusOverlay" Property="Opacity" Value="1"/>
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="Arrow" Property="Fill" Value="#2B5FF0"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ToggleButton" Property="Background" Value="#F0F0F0"/>
                                <Setter TargetName="ToggleButton" Property="BorderBrush" Value="#D0D0D0"/>
                                <Setter TargetName="Arrow" Property="Fill" Value="#D0D0D0"/>
                                <Setter Property="Foreground" Value="#A0A0A0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>

            <!-- Стиль для элементов внутри выпадающего списка -->
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Padding" Value="8,6"/>
                        <Setter Property="FontSize" Value="14"/>
                        <Setter Property="FontFamily" Value="Segoe UI Variable"/>
                        <Setter Property="Background" Value="#FFFFFF"/>
                        <Setter Property="Foreground" Value="#1A1C1E"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="itemBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="#E0E3E7"
                                    BorderThickness="0,0,0,1"
                                    Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="itemBorder" Property="Background" Value="#F0F3F7"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="itemBorder" Property="Background" Value="#E0E3E7"/>
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter TargetName="itemBorder" Property="Background" Value="#F0F0F0"/>
                                            <Setter Property="Foreground" Value="#A0A0A0"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Шаблон для кнопки-триггера ComboBox -->
        <ControlTemplate x:Key="ComboBoxToggleButtonTemplate" TargetType="ToggleButton">
            <Border x:Name="Border" 
            Background="{TemplateBinding Background}"
            BorderBrush="{TemplateBinding BorderBrush}"
            BorderThickness="{TemplateBinding BorderThickness}"
            CornerRadius="8">
                <Grid>
                    <Path x:Name="Arrow"
                  Width="10"
                  Height="6"
                  Fill="#1A1C1E"
                  Stretch="Uniform"
                  HorizontalAlignment="Right"
                  VerticalAlignment="Center"
                  Margin="0,0,12,0"
                  Data="M0,0 L1,0 0.5,1 Z"/>
                </Grid>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Border" Property="BorderBrush" Value="#A0A5AB"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter TargetName="Border" Property="Background" Value="#E0E3E7"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter TargetName="Border" Property="Background" Value="#F0F0F0"/>
                    <Setter TargetName="Border" Property="BorderBrush" Value="#D0D0D0"/>
                    <Setter TargetName="Arrow" Property="Fill" Value="#D0D0D0"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

    </UserControl.Resources>

    <Grid Background="#F8F9FA">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок и управление -->
        <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="30,20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Заголовок -->
                <Grid Grid.Row="0" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="📅 Расписание занятий" 
                                    FontSize="22" 
                                    FontWeight="SemiBold" 
                                    Foreground="#333"/>
                        <TextBlock Text="Просмотр и редактирование расписания занятий" 
                                    FontSize="13" 
                                    Foreground="#999"
                                    Margin="0,5,0,0"/>
                    </StackPanel>

                    <!-- Выбор класса -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBlock Text="Группа:" 
               FontSize="13" 
               Foreground="#666"
               VerticalAlignment="Center"
               Margin="0,0,10,0"/>
                        <ComboBox x:Name="ClassComboBox" 
              Width="150" 
              Height="38"
              Style="{StaticResource FormComboBox}"
              SelectionChanged="ClassComboBox_SelectionChanged"
              DisplayMemberPath="Name"
              SelectedValuePath="Id" Margin="0,0,0,0"/>
                    </StackPanel>
                </Grid>

                <!-- Кнопки управления -->
                <StackPanel Grid.Row="1" Orientation="Horizontal">
                    <Button Content="➕ Добавить занятие" 
        Style="{StaticResource PrimaryButton}"
        Click="AddLesson_Click"/>
                    <Button Content="✏️ Редактировать" 
        Style="{StaticResource SecondaryButton}"
        Click="EditLesson_Click"
        Margin="10,0,0,0"/>
                    <Button Content="🗑️ Удалить" 
                            Style="{StaticResource SecondaryButton}"
                            Click="DeleteLesson_Click"
                            Margin="10,0,0,0"/>
                    <Button Content="🔄 Обновить" 
                            Style="{StaticResource SecondaryButton}"
                            Click="Refresh_Click"
                            Margin="10,0,0,0"/>
                    <Button Content="📄 Экспорт в PDF" 
                            Style="{StaticResource SecondaryButton}"
                            Click="ExportToPdf_Click"
                            Margin="10,0,0,0"/>

                    <!-- Навигация по неделям -->
                    <Border Background="#F5F7FF" 
                            Padding="10,8" 
                            CornerRadius="6" 
                            Margin="20,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="◀" 
                                    Style="{StaticResource SecondaryButton}"
                                    Width="35"
                                    Height="35"
                                    Padding="0"
                                    Click="PreviousWeek_Click"/>
                            <TextBlock x:Name="WeekText" 
                                       Text="Текущая неделя" 
                                       FontSize="13" 
                                       FontWeight="SemiBold"
                                       Foreground="#5271FF"
                                       VerticalAlignment="Center"
                                       Margin="15,0"/>
                            <Button Content="▶" 
                                    Style="{StaticResource SecondaryButton}"
                                    Width="35"
                                    Height="35"
                                    Padding="0"
                                    Click="NextWeek_Click"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" 
                Background="White" 
                BorderBrush="#E0E0E0" 
                BorderThickness="1"
                CornerRadius="8"
                Margin="30,20,30,20">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                <Grid x:Name="ScheduleGrid" MouseDown="ScheduleGrid_MouseDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <!-- время -->
                        <ColumnDefinition Width="*"/>
                        <!-- Пн -->
                        <ColumnDefinition Width="*"/>
                        <!-- Вт -->
                        <ColumnDefinition Width="*"/>
                        <!-- Ср -->
                        <ColumnDefinition Width="*"/>
                        <!-- Чт -->
                        <ColumnDefinition Width="*"/>
                        <!-- Пт -->
                        <ColumnDefinition Width="*"/>
                        <!-- Сб -->
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="50"/>
                        <!-- заголовки дней -->
                        <RowDefinition Height="80"/>
                        <!-- 1 урок -->
                        <RowDefinition Height="80"/>
                        <!-- 2 -->
                        <RowDefinition Height="80"/>
                        <!-- 3 -->
                        <RowDefinition Height="80"/>
                        <!-- 4 -->
                        <RowDefinition Height="80"/>
                        <!-- 5 -->
                        <RowDefinition Height="80"/>
                        <!-- 6 -->
                        <RowDefinition Height="80"/>
                        <!-- 7 -->
                        <RowDefinition Height="80"/>
                        <!-- 8 -->
                    </Grid.RowDefinitions>

                    <!-- Заголовки дней недели -->
                    <Border Grid.Row="0" Grid.Column="0" Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="0,0,1,1"/>

                    <Border Grid.Row="0" Grid.Column="1" Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="0,0,1,1">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="Понедельник" Style="{StaticResource DayHeaderStyle}"/>
                            <TextBlock x:Name="MondayDate" FontSize="11" Foreground="#999" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="0" Grid.Column="2" Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="0,0,1,1">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="Вторник" Style="{StaticResource DayHeaderStyle}"/>
                            <TextBlock x:Name="TuesdayDate" FontSize="11" Foreground="#999" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="0" Grid.Column="3" Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="0,0,1,1">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="Среда" Style="{StaticResource DayHeaderStyle}"/>
                            <TextBlock x:Name="WednesdayDate" FontSize="11" Foreground="#999" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="0" Grid.Column="4" Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="0,0,1,1">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="Четверг" Style="{StaticResource DayHeaderStyle}"/>
                            <TextBlock x:Name="ThursdayDate" FontSize="11" Foreground="#999" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="0" Grid.Column="5" Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="0,0,1,1">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="Пятница" Style="{StaticResource DayHeaderStyle}"/>
                            <TextBlock x:Name="FridayDate" FontSize="11" Foreground="#999" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="0" Grid.Column="6" Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="0,0,1,1">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="Суббота" Style="{StaticResource DayHeaderStyle}"/>
                            <TextBlock x:Name="SaturdayDate" FontSize="11" Foreground="#999" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Время 1–8 урок -->
                    <!-- 1 урок -->
                    <Border Grid.Row="1" Grid.Column="0" Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="0,0,1,1">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="8:00" FontSize="12" FontWeight="SemiBold" Foreground="#333"/>
                            <TextBlock Text="9:30" FontSize="10" Foreground="#999"/>
                        </StackPanel>
                    </Border>

                    <!-- 2 урок -->
                    <Border Grid.Row="2" Grid.Column="0" Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="0,0,1,1">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="9:40" FontSize="12" FontWeight="SemiBold" Foreground="#333"/>
                            <TextBlock Text="11:10" FontSize="10" Foreground="#999"/>
                        </StackPanel>
                    </Border>

                    <!-- 3 урок -->
                    <Border Grid.Row="3" Grid.Column="0" Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="0,0,1,1">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="11:20" FontSize="12" FontWeight="SemiBold" Foreground="#333"/>
                            <TextBlock Text="12:50" FontSize="10" Foreground="#999"/>
                        </StackPanel>
                    </Border>

                    <!-- 4 урок -->
                    <Border Grid.Row="4" Grid.Column="0" Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="0,0,1,1">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="13:45" FontSize="12" FontWeight="SemiBold" Foreground="#333"/>
                            <TextBlock Text="15:15" FontSize="10" Foreground="#999"/>
                        </StackPanel>
                    </Border>

                    <!-- 5 урок -->
                    <Border Grid.Row="5" Grid.Column="0" Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="0,0,1,1">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="15:25" FontSize="12" FontWeight="SemiBold" Foreground="#333"/>
                            <TextBlock Text="16:55" FontSize="10" Foreground="#999"/>
                        </StackPanel>
                    </Border>

                    <!-- 6 урок -->
                    <Border Grid.Row="6" Grid.Column="0" Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="0,0,1,1">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="17:05" FontSize="12" FontWeight="SemiBold" Foreground="#333"/>
                            <TextBlock Text="18:35" FontSize="10" Foreground="#999"/>
                        </StackPanel>
                    </Border>

                    <!-- 7 урок -->
                    <Border Grid.Row="7" Grid.Column="0" Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="0,0,1,1">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="18:45" FontSize="12" FontWeight="SemiBold" Foreground="#333"/>
                            <TextBlock Text="20:15" FontSize="10" Foreground="#999"/>
                        </StackPanel>
                    </Border>



                    <!-- Пустые ячейки сетки (1–8 урок, Пн–Сб) -->
                    <!-- 1 урок -->
                    <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource ScheduleCellStyle}" />
                    <Border Grid.Row="1" Grid.Column="2" Style="{StaticResource ScheduleCellStyle}" />
                    <Border Grid.Row="1" Grid.Column="3" Style="{StaticResource ScheduleCellStyle}" />
                    <Border Grid.Row="1" Grid.Column="4" Style="{StaticResource ScheduleCellStyle}" />
                    <Border Grid.Row="1" Grid.Column="5" Style="{StaticResource ScheduleCellStyle}" />
                    <Border Grid.Row="1" Grid.Column="6" Style="{StaticResource ScheduleCellStyle}" />

                    <!-- 2 урок -->
                    <Border Grid.Row="2" Grid.Column="1" Style="{StaticResource ScheduleCellStyle}" />
                    <Border Grid.Row="2" Grid.Column="2" Style="{StaticResource ScheduleCellStyle}" />
                    <Border Grid.Row="2" Grid.Column="3" Style="{StaticResource ScheduleCellStyle}" />
                    <Border Grid.Row="2" Grid.Column="4" Style="{StaticResource ScheduleCellStyle}" />
                    <Border Grid.Row="2" Grid.Column="5" Style="{StaticResource ScheduleCellStyle}" />
                    <Border Grid.Row="2" Grid.Column="6" Style="{StaticResource ScheduleCellStyle}" />

                    <!-- 3 урок -->
                    <Border Grid.Row="3" Grid.Column="1" Style="{StaticResource ScheduleCellStyle}" />
                    <Border Grid.Row="3" Grid.Column="2" Style="{StaticResource ScheduleCellStyle}" />
                    <Border Grid.Row="3" Grid.Column="3" Style="{StaticResource ScheduleCellStyle}" />
                    <Border Grid.Row="3" Grid.Column="4" Style="{StaticResource ScheduleCellStyle}" />
                    <Border Grid.Row="3" Grid.Column="5" Style="{StaticResource ScheduleCellStyle}" />
                    <Border Grid.Row="3" Grid.Column="6" Style="{StaticResource ScheduleCellStyle}" />

                    <!-- 4 урок -->
                    <Border Grid.Row="4" Grid.Column="1" Style="{StaticResource ScheduleCellStyle}" />
                    <Border Grid.Row="4" Grid.Column="2" Style="{StaticResource ScheduleCellStyle}" />
                    <Border Grid.Row="4" Grid.Column="3" Style="{StaticResource ScheduleCellStyle}" />
                    <Border Grid.Row="4" Grid.Column="4" Style="{StaticResource ScheduleCellStyle}" />
                    <Border Grid.Row="4" Grid.Column="5" Style="{StaticResource ScheduleCellStyle}" />
                    <Border Grid.Row="4" Grid.Column="6" Style="{StaticResource ScheduleCellStyle}" />

                    <!-- 5 урок -->
                    <Border Grid.Row="5" Grid.Column="1" Style="{StaticResource ScheduleCellStyle}" />
                    <Border Grid.Row="5" Grid.Column="2" Style="{StaticResource ScheduleCellStyle}" />
