<UserControl x:Class="Diplom.HomeworkEditView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Diplom"
             mc:Ignorable="d" 
             d:DesignHeight="500" d:DesignWidth="600">

    <UserControl.Resources>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="#5271FF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="6" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4060E8"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#666"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F8F9FA"/>
                    <Setter Property="BorderBrush" Value="#5271FF"/>
                    <Setter Property="Foreground" Value="#5271FF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Background="#F8F9FA">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0" 
                BorderThickness="0,0,0,1" Padding="30,20">
            <Grid>
                <StackPanel>
                    <TextBlock x:Name="TitleText" Text="📝 Домашнее задание" 
                               FontSize="22" FontWeight="SemiBold" 
                               Foreground="#333"/>
                    <TextBlock x:Name="SubtitleText" 
                               Text="Заполните информацию о задании" 
                               FontSize="13" Foreground="#999"
                               Margin="0,5,0,0"/>
                </StackPanel>
                <Button Content="← Назад" 
                        Style="{StaticResource SecondaryButton}" 
                        HorizontalAlignment="Right"
                        Click="Back_Click"/>
            </Grid>
        </Border>

        <!-- Форма -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Border Margin="40,30" Padding="30" Background="White"
                    CornerRadius="8" BorderBrush="#E0E0E0" BorderThickness="1">
                <StackPanel>
                    <!-- Класс и Предмет -->
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Класс" FontSize="12" Foreground="#999" 
                                       Margin="0,0,0,4"/>
                            <TextBlock x:Name="ClassNameText" FontSize="15" 
                                       FontWeight="SemiBold" Foreground="#333"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Предмет" FontSize="12" Foreground="#999" 
                                       Margin="0,0,0,4"/>
                            <TextBlock x:Name="SubjectNameText" FontSize="15" 
                                       FontWeight="SemiBold" Foreground="#333"/>
                        </StackPanel>
                    </Grid>

                    <!-- Задание -->
                    <TextBlock Text="Текст задания *" FontSize="12" Foreground="#999" 
                               Margin="0,0,0,6"/>
                    <TextBox x:Name="TaskTextBox" Height="120" 
                             TextWrapping="Wrap" AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             FontSize="13" Padding="12"
                             BorderBrush="#E0E0E0" BorderThickness="1"
                             Margin="0,0,0,20"/>

                    <!-- Дата сдачи -->
                    <TextBlock Text="Срок сдачи *" FontSize="12" Foreground="#999" 
                               Margin="0,0,0,6"/>
                    <DatePicker x:Name="DeadlinePicker" Height="38"
                                FontSize="13" Margin="0,0,0,20"/>

                    <!-- Ссылка -->
                    <TextBlock Text="Ссылка на файл" FontSize="12" Foreground="#999" 
                               Margin="0,0,0,6"/>
                    <TextBox x:Name="FileLinkTextBox" Height="36"
                             FontSize="13" Padding="12,8"
                             BorderBrush="#E0E0E0" BorderThickness="1"
                             Margin="0,0,0,20"/>

                    <!-- Комментарий -->
                    <TextBlock Text="Комментарий" FontSize="12" Foreground="#999" 
                               Margin="0,0,0,6"/>
                    <TextBox x:Name="CommentTextBox" Height="70"
                             TextWrapping="Wrap"
                             FontSize="13" Padding="12"
                             BorderBrush="#E0E0E0" BorderThickness="1"
                             Margin="0,0,0,30"/>

                    <!-- Кнопки -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Отмена" 
                                Style="{StaticResource SecondaryButton}" 
                                Width="100"
                                Click="Cancel_Click"/>
                        <Button Content="💾 Сохранить" 
                                Style="{StaticResource PrimaryButton}" 
                                Width="130"
                                Click="Save_Click" 
                                Margin="10,0,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</UserControl>