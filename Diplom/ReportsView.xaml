<UserControl x:Class="Diplom.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" d:DesignWidth="900"
             Background="#F8F9FA" Height="933">

    <UserControl.Resources>
        <!-- Карточка -->
        <Style x:Key="ReportCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="25"/>
            <Setter Property="Margin" Value="0,0,0,20"/>
        </Style>

        <Style x:Key="ReportTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#333"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
        </Style>

        <Style x:Key="StatValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#5271FF"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="StatLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#666"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,6,0,0"/>
        </Style>

        <!-- Подписи форм -->
        <Style x:Key="FormLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="#666"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <!-- DatePicker -->
        <Style x:Key="FormDatePicker" TargetType="DatePicker">
            <Setter Property="Height" Value="38"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DatePicker">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <DatePickerTextBox x:Name="PART_TextBox" 
                                                   Grid.Column="0"
                                                   Margin="12,0,0,0"
                                                   VerticalAlignment="Center"
                                                   BorderThickness="0"
                                                   Background="Transparent"/>
                                <Button x:Name="PART_Button"
                                        Grid.Column="1"
                                        Content="📅"
                                        Width="30"
                                        BorderThickness="0"
                                        Background="Transparent"
                                        Foreground="#666"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ComboBox -->

        <!-- Упрощенный стиль для ComboBox -->
        <Style x:Key="FormComboBox" TargetType="ComboBox">
            <Setter Property="Margin" Value="0,0,0,16"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable"/>
            <Setter Property="BorderBrush" Value="#E0E3E7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#1A1C1E"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <!-- Основной контейнер ComboBox -->
                            <ToggleButton x:Name="ToggleButton"
                                  Background="{TemplateBinding Background}"
                                  BorderBrush="{TemplateBinding BorderBrush}"
                                  BorderThickness="{TemplateBinding BorderThickness}"
                                  IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                  Focusable="False">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Border" 
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="8">
                                            <Grid>
                                                <!-- Стрелка вниз -->
                                                <Path x:Name="Arrow"
                                              Width="10"
                                              Height="6"
                                              Fill="#1A1C1E"
                                              Stretch="Uniform"
                                              HorizontalAlignment="Right"
                                              VerticalAlignment="Center"
                                              Margin="0,0,12,0"
                                              Data="M0,0 L1,0 0.5,1 Z"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Border" Property="BorderBrush" Value="#A0A5AB"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="Border" Property="Background" Value="#E0E3E7"/>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter TargetName="Border" Property="Background" Value="#F0F0F0"/>
                                                <Setter TargetName="Border" Property="BorderBrush" Value="#D0D0D0"/>
                                                <Setter TargetName="Arrow" Property="Fill" Value="#D0D0D0"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <!-- Поле вывода выбранного значения -->
                            <ContentPresenter x:Name="ContentSite"
                                      Content="{TemplateBinding SelectionBoxItem}"
                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                      ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                      Margin="{TemplateBinding Padding}"
                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                      IsHitTestVisible="False"/>

                            <!-- Стрелка вниз -->
                            <Path x:Name="Arrow"
                          Width="10"
                          Height="6"
                          Fill="#1A1C1E"
                          Stretch="Uniform"
                          HorizontalAlignment="Right"
                          VerticalAlignment="Center"
                          Margin="0,0,12,0"
                          Data="M0,0 L1,0 0.5,1 Z"/>

                            <!-- Выпадающий список -->
                            <Popup x:Name="PART_Popup"
                           Placement="Bottom"
                           IsOpen="{TemplateBinding IsDropDownOpen}"
                           AllowsTransparency="True"
                           Focusable="False"
                           PopupAnimation="Slide">
                                <Border Background="#FFFFFF"
                                BorderBrush="#E0E3E7"
                                BorderThickness="1"
                                CornerRadius="8">
                                    <ScrollViewer>
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>

                            <!-- Обводка при фокусе -->
                            <Border x:Name="focusOverlay"
                            CornerRadius="8"
                            BorderThickness="2"
                            BorderBrush="#2B5FF0"
                            Opacity="0"
                            IsHitTestVisible="False"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ToggleButton" Property="BorderBrush" Value="#A0A5AB"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="focusOverlay" Property="Opacity" Value="1"/>
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="Arrow" Property="Fill" Value="#2B5FF0"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ToggleButton" Property="Background" Value="#F0F0F0"/>
                                <Setter TargetName="ToggleButton" Property="BorderBrush" Value="#D0D0D0"/>
                                <Setter TargetName="Arrow" Property="Fill" Value="#D0D0D0"/>
                                <Setter Property="Foreground" Value="#A0A0A0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>

            <!-- Стиль для элементов внутри выпадающего списка -->
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Padding" Value="8,6"/>
                        <Setter Property="FontSize" Value="14"/>
                        <Setter Property="FontFamily" Value="Segoe UI Variable"/>
                        <Setter Property="Background" Value="#FFFFFF"/>
                        <Setter Property="Foreground" Value="#1A1C1E"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="itemBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="#E0E3E7"
                                    BorderThickness="0,0,0,1"
                                    Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="itemBorder" Property="Background" Value="#F0F3F7"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="itemBorder" Property="Background" Value="#E0E3E7"/>
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter TargetName="itemBorder" Property="Background" Value="#F0F0F0"/>
                                            <Setter Property="Foreground" Value="#A0A0A0"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Шаблон для кнопки-триггера ComboBox -->
        <ControlTemplate x:Key="ComboBoxToggleButtonTemplate" TargetType="ToggleButton">
            <Border x:Name="Border" 
            Background="{TemplateBinding Background}"
            BorderBrush="{TemplateBinding BorderBrush}"
            BorderThickness="{TemplateBinding BorderThickness}"
            CornerRadius="8">
                <Grid>
                    <Path x:Name="Arrow"
                  Width="10"
                  Height="6"
                  Fill="#1A1C1E"
                  Stretch="Uniform"
                  HorizontalAlignment="Right"
                  VerticalAlignment="Center"
                  Margin="0,0,12,0"
                  Data="M0,0 L1,0 0.5,1 Z"/>
                </Grid>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Border" Property="BorderBrush" Value="#A0A5AB"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter TargetName="Border" Property="Background" Value="#E0E3E7"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter TargetName="Border" Property="Background" Value="#F0F0F0"/>
                    <Setter TargetName="Border" Property="BorderBrush" Value="#D0D0D0"/>
                    <Setter TargetName="Arrow" Property="Fill" Value="#D0D0D0"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <!-- Тень для выпадающего списка -->
        <DropShadowEffect x:Key="DropShadow" 
                          BlurRadius="10" 
                          ShadowDepth="2" 
                          Opacity="0.2" 
                          Color="Black"/>

        <!-- Кнопки -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="#5271FF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="6" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4060E8"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#666"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F8F9FA"/>
                    <Setter Property="BorderBrush" Value="#5271FF"/>
                    <Setter Property="Foreground" Value="#5271FF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для DataGrid -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#F8F9FA"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#F0F0F0"/>
            <Setter Property="VerticalGridLinesBrush" Value="Transparent"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F8F9FA"/>
            <Setter Property="Foreground" Value="#333"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="15,12"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Height" Value="45"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F5F7FF"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#EEF2FF"/>
                    <Setter Property="Foreground" Value="#5271FF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Foreground" Value="#333"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="#5271FF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ШАПКА -->
        <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="30,20">
            <Grid>
                <StackPanel>
                    <TextBlock Text="📊 Отчёты и аналитика" 
                               FontSize="22" 
                               FontWeight="SemiBold" 
                               Foreground="#333"/>
                    <TextBlock Text="Сводные показатели и детальные отчёты по журналу" 
                               FontSize="13" 
                               Foreground="#999" 
                               Margin="0,5,0,0"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="📄 Экспорт в PDF" 
                            Style="{StaticResource PrimaryButton}"
                            Click="ExportToPdf_Click"/>
                    <Button Content="🔄 Обновить" 
                            Style="{StaticResource SecondaryButton}"
                            Click="RefreshData_Click"
                            Margin="10,0,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ОСНОВНОЙ БЛОК -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="30,20">
            <StackPanel>

                <!-- Параметры отчёта -->
                <Border Style="{StaticResource ReportCardStyle}">
                    <StackPanel>
                        <Grid Margin="0,0,0,15">
                            <TextBlock Text="⚙️ Параметры отчёта" Style="{StaticResource ReportTitleStyle}" Margin="0"/>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Период с -->
                            <StackPanel Grid.Column="0" Margin="0,0,15,0">
                                <TextBlock Text="Период с" Style="{StaticResource FormLabel}"/>
                                <DatePicker x:Name="StartDatePicker" 
                                            Style="{StaticResource FormDatePicker}"
                                            Width="160"/>
                            </StackPanel>

                            <!-- по -->
                            <StackPanel Grid.Column="1" Margin="0,0,15,0">
                                <TextBlock Text="по" Style="{StaticResource FormLabel}"/>
                                <DatePicker x:Name="EndDatePicker" 
                                            Style="{StaticResource FormDatePicker}"
                                            Width="160"/>
                            </StackPanel>

                            <!-- Класс -->
                            <StackPanel x:Name="ClassFilterPanel" Grid.Column="2" Margin="0,0,15,0">
                                <TextBlock Text="Класс" Style="{StaticResource FormLabel}"/>
                                <ComboBox x:Name="ClassComboBox"
                                          Style="{StaticResource FormComboBox}"
                                          Width="180"
                                          DisplayMemberPath="Name"
                                          SelectedValuePath="Id" Height="38"/>
                            </StackPanel>

                            <!-- Тип отчёта -->
                            <StackPanel Grid.Column="3" Margin="0,0,15,0">
                                <TextBlock Text="Тип отчёта" Style="{StaticResource FormLabel}"/>
                                <ComboBox x:Name="ReportTypeComboBox" 
                                          Style="{StaticResource FormComboBox}"
                                          SelectionChanged="ReportTypeComboBox_SelectionChanged"
                                          Width="220" Height="38">
                                    <ComboBoxItem Content="Общая статистика" IsSelected="True"/>
                                    <ComboBoxItem Content="Посещаемость"/>
                                    <ComboBoxItem Content="Успеваемость"/>
                                    <ComboBoxItem Content="Нагрузка преподавателей"/>
                                </ComboBox>
                            </StackPanel>

                            <!-- Кнопка -->
                            <Button Grid.Column="4"
                                    Content="Сформировать" 
                                    Style="{StaticResource PrimaryButton}"
                                    Click="GenerateReport_Click"
                                    VerticalAlignment="Bottom"
                                    HorizontalAlignment="Left" Margin="0,0,0,16"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ОБЩАЯ СТАТИСТИКА -->
                <Border Style="{StaticResource ReportCardStyle}">
                    <StackPanel>
                        <TextBlock Text="📈 Общая статистика" Style="{StaticResource ReportTitleStyle}"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Преподаватели -->
                            <Border Grid.Column="0" Background="#F5F7FF" CornerRadius="8" Padding="20" Margin="0,0,10,0">
                                <StackPanel>
                                    <TextBlock Text="👨‍🏫" FontSize="24" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                    <TextBlock x:Name="TeachersCountText" Text="0" Style="{StaticResource StatValueStyle}"/>
                                    <TextBlock Text="Преподавателей" Style="{StaticResource StatLabelStyle}"/>
                                </StackPanel>
                            </Border>

                            <!-- Студенты -->
                            <Border Grid.Column="1" Background="#F5F7FF" CornerRadius="8" Padding="20" Margin="0,0,10,0">
                                <StackPanel>
                                    <TextBlock Text="👥" FontSize="24" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                    <TextBlock x:Name="StudentsCountText" Text="0" Style="{StaticResource StatValueStyle}"/>
                                    <TextBlock Text="Студентов" Style="{StaticResource StatLabelStyle}"/>
                                </StackPanel>
                            </Border>

                            <!-- Занятий -->
                            <Border Grid.Column="2" Background="#F5F7FF" CornerRadius="8" Padding="20" Margin="0,0,10,0">
                                <StackPanel>
                                    <TextBlock Text="📚" FontSize="24" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                    <TextBlock x:Name="LessonsCountText" Text="0" Style="{StaticResource StatValueStyle}"/>
                                    <TextBlock Text="Занятий" Style="{StaticResource StatLabelStyle}"/>
                                </StackPanel>
                            </Border>

                            <!-- Средний балл -->
                            <Border Grid.Column="3" Background="#F5F7FF" CornerRadius="8" Padding="20">
                                <StackPanel>
                                    <TextBlock Text="⭐" FontSize="24" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                    <TextBlock x:Name="AverageGradeText" Text="0.0" Style="{StaticResource StatValueStyle}"/>
                                    <TextBlock Text="Средний балл" Style="{StaticResource StatLabelStyle}"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ДЕТАЛЬНАЯ ТАБЛИЦА -->
                <Border Style="{StaticResource ReportCardStyle}">
                    <StackPanel>
                        <Grid Margin="0,0,0,15">
                            <TextBlock Text="📋 Детальный отчёт" Style="{StaticResource ReportTitleStyle}" Margin="0"/>
                            <Border Background="#F5F7FF" 
                                    Padding="10,6" 
                                    CornerRadius="6" 
                                    HorizontalAlignment="Right">
                                <TextBlock x:Name="RecordsCountText" 
                                           Text="0 записей" 
                                           FontSize="12" 
                                           FontWeight="SemiBold"
                                           Foreground="#5271FF"/>
                            </Border>
                        </Grid>

                        <Border BorderBrush="#E0E0E0" 
                                BorderThickness="1" 
                                CornerRadius="8">
                            <DataGrid x:Name="ReportGrid"
                                      AutoGenerateColumns="True"
                                      IsReadOnly="True"
                                      MinHeight="300"
                                      MaxHeight="400"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      BorderThickness="0"/>
                        </Border>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- СТАТУС -->
        <Border Grid.Row="2" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Padding="30,12">
            <Grid>
                <TextBlock x:Name="StatusText" 
                           Text="Готово к работе" 
                           FontSize="12" 
                           Foreground="#666"
                           VerticalAlignment="Center"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock Text="Последнее обновление: " 
                               FontSize="12" 
                               Foreground="#999"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="LastUpdateText"
                               Text="{Binding CurrentDateTime}"
                               FontSize="12" 
                               FontWeight="Medium"
                               Foreground="#5271FF"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
