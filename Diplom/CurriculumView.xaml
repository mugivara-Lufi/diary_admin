<UserControl x:Class="Diplom.CurriculumView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Diplom"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1200"
             Background="#F8F9FA">

    <UserControl.Resources>

        <!-- Стиль для основной кнопки -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="#5271FF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="6" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4060E8"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для вторичной кнопки -->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#666"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F8F9FA"/>
                    <Setter Property="BorderBrush" Value="#5271FF"/>
                    <Setter Property="Foreground" Value="#5271FF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для опасной кнопки -->
        <Style x:Key="DangerButton" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="#E53E3E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="6" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#D32F2F"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SearchTextBox" TargetType="TextBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Grid>
                            <Border Background="White" 
                                    BorderBrush="{TemplateBinding BorderBrush}" 
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6">
                                <Grid>
                                    <ScrollViewer x:Name="PART_ContentHost" 
                                                  Margin="12,0,12,0"
                                                  VerticalAlignment="Center"/>
                                    <TextBlock Text="{TemplateBinding Tag}" 
                                               Foreground="#999" 
                                               FontSize="13"
                                               Margin="12,0,12,0"
                                               VerticalAlignment="Center"
                                               IsHitTestVisible="False"
                                               x:Name="PlaceholderText"
                                               Visibility="Collapsed"/>
                                </Grid>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="PlaceholderText" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="Text" Value="{x:Null}">
                                <Setter TargetName="PlaceholderText" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#5271FF"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsFocused" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="PlaceholderText" Property="Visibility" Value="Collapsed"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>


    </UserControl.Resources>

    <Grid Background="#F8F9FA">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Панель управления -->
        <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="30,20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Заголовок и поиск -->
                <Grid Grid.Row="0" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="📋 Управление учебными планами" 
                                   FontSize="22" 
                                   FontWeight="SemiBold" 
                                   Foreground="#333"/>
                        <TextBlock Text="Составление и редактирование учебных планов для групп" 
                                   FontSize="13" 
                                   Foreground="#999"
                                   Margin="0,5,0,0"/>
                    </StackPanel>

                    <!-- Поиск справа -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBlock Text="🔍" FontSize="16" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="#999"/>
                        <TextBox x:Name="SearchTextBox" 
                                 Style="{StaticResource SearchTextBox}" 
                                 Width="280" 
                                 Tag="Поиск по названию, группе..." 
                                 TextChanged="SearchTextBox_TextChanged"/>
                    </StackPanel>
                </Grid>

                <!-- Кнопки действий -->
                <StackPanel Grid.Row="1" Orientation="Horizontal">
                    <Button Content="➕ Добавить план" 
                            Style="{StaticResource PrimaryButton}" 
                            Click="CreatePlanButton_Click"/>
                    <Button Content="✏️ Редактировать" 
                            Style="{StaticResource SecondaryButton}" 
                            Click="EditPlanButton_Click" 
                            Margin="10,0,0,0"/>
                    <Button Content="🗑️ Удалить" 
                            Style="{StaticResource DangerButton}" 
                            Click="DeletePlanButton_Click" 
                            Margin="10,0,0,0"/>
                    <Button Content="🔄 Обновить" 
                            Style="{StaticResource SecondaryButton}" 
                            Click="RefreshButton_Click" 
                            Margin="10,0,0,0"/>

                    <!-- Статистика справа -->
                    <Border Background="#F5F7FF" 
                            Padding="15,8" 
                            CornerRadius="6" 
                            Margin="20,0,0,0"
                            HorizontalAlignment="Right">
                        <TextBlock x:Name="CountText" 
                                   Text="0 планов" 
                                   FontSize="13" 
                                   FontWeight="SemiBold"
                                   Foreground="#5271FF"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Таблица учебных планов -->
        <Border Grid.Row="1" 
                Background="White" 
                BorderBrush="#E0E0E0" 
                BorderThickness="1"
                CornerRadius="8"
                Margin="30,20,30,20">
            <DataGrid x:Name="CurriculumGrid" 
                      AutoGenerateColumns="False" 
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      SelectionUnit="FullRow"
                      HeadersVisibility="Column"
                      BorderThickness="0"
                      SelectionChanged="CurriculumGrid_SelectionChanged">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Номер" Width="70" Binding="{Binding Id}">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#999"/>
                                <Setter Property="FontWeight" Value="Medium"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Название плана" Width="200" Binding="{Binding Name}">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Группа" Width="150" Binding="{Binding ClassName}"/>
                    <DataGridTextColumn Header="Учебный год" Width="120" Binding="{Binding AcademicYear}"/>
                    <DataGridTextColumn Header="Предметов" Width="100" Binding="{Binding SubjectsCount}">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="FontWeight" Value="Medium"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTemplateColumn Header="Текущий" Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsCurrent}" IsEnabled="False" HorizontalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="Действия" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Content="✏️" Click="EditPlanButton_Click" Tag="{Binding}" 
                                            Background="Transparent" BorderThickness="0" FontSize="14" Margin="5,0" 
                                            ToolTip="Редактировать" Cursor="Hand"/>
                                    <Button Content="📋" Click="EditSubjects_Click" Tag="{Binding}" 
                                            Background="Transparent" BorderThickness="0" FontSize="14" Margin="5,0" 
                                            ToolTip="Предметы" Cursor="Hand"/>
                                    <Button Content="🗑️" Click="DeletePlanButton_Click" Tag="{Binding}" 
                                            Background="Transparent" BorderThickness="0" FontSize="14" Margin="5,0" 
                                            Foreground="#E53E3E" ToolTip="Удалить" Cursor="Hand"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Статус бар -->
        <Border Grid.Row="2" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Padding="30,12">
            <Grid>
                <TextBlock x:Name="StatusText" 
                           Text="Готово к работе" 
                           FontSize="12" 
                           Foreground="#666"
                           VerticalAlignment="Center"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock Text="Последнее обновление: " 
                               FontSize="12" 
                               Foreground="#999"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="LastUpdateText" 
                               Text="только что" 
                               FontSize="12" 
                               Foreground="#5271FF"
                               FontWeight="Medium"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>