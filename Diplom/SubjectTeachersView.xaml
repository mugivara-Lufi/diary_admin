<UserControl x:Class="Diplom.SubjectTeachersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Diplom"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" Padding="25">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="👨‍🏫 Преподаватели" FontSize="20" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,10"/>
            <TextBlock x:Name="SubjectNameText" Grid.Row="1" FontSize="14" Foreground="#5271FF" Margin="0,0,0,20"/>

            <DataGrid x:Name="TeachersGrid" Grid.Row="2" AutoGenerateColumns="False" CanUserAddRows="False"
                      HeadersVisibility="Column" Margin="0,0,0,15" MaxHeight="300">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ФИО" Width="*" Binding="{Binding FullName}"/>
                    <DataGridTextColumn Header="Дисциплина" Width="120" Binding="{Binding SubjectName}"/>
                    <DataGridTemplateColumn Header="Действия" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="🗑️" Click="RemoveTeacher_Click" Tag="{Binding}"
                                        Background="Transparent" BorderThickness="0" Foreground="#E53E3E" Cursor="Hand"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,10,0,0">
                <ComboBox x:Name="TeacherComboBox" Width="250" Height="35" DisplayMemberPath="FullName"
                          SelectedValuePath="Id" Margin="0,0,10,0"/>
                <Button Content="Добавить" Width="80" Height="35" Style="{StaticResource PrimaryButton}" Click="AddTeacher_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
