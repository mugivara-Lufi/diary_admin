<UserControl x:Class="Diplom.TeacherScheduleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="900"
             Background="#F8F9FA">

    <UserControl.Resources>
        <!-- Стиль для карточки -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <!-- Стиль для ячейки расписания -->
        <Style x:Key="ScheduleCellStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="MinHeight" Value="80"/>
        </Style>

        <!-- Стиль для карточки урока -->
        <Style x:Key="LessonCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#EEF2FF"/>
            <Setter Property="BorderBrush" Value="#5271FF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <!-- Стиль для кнопок навигации по неделям -->
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="35"/>
            <Setter Property="Width" Value="35"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#666"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F5F7FF"/>
                    <Setter Property="BorderBrush" Value="#5271FF"/>
                    <Setter Property="Foreground" Value="#5271FF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для основной кнопки -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="#5271FF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="6" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4060E8"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для вторичной кнопки -->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#666"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F8F9FA"/>
                    <Setter Property="BorderBrush" Value="#5271FF"/>
                    <Setter Property="Foreground" Value="#5271FF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для заголовков дней недели -->
        <Style x:Key="DayHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#333"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Панель управления -->
        <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="30,20">
            <Grid>
                <StackPanel>
                    <TextBlock Text="📅 Расписание занятий" 
                               FontSize="22" 
                               FontWeight="SemiBold" 
                               Foreground="#333"/>
                    <TextBlock Text="Просмотр вашего расписания на неделю" 
                               FontSize="13" 
                               Foreground="#999"
                               Margin="0,5,0,0"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <!-- Навигация по неделям -->
                    <Border Background="#F5F7FF" Padding="10,8" CornerRadius="6" Margin="0,0,15,0">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="◀" Style="{StaticResource NavButtonStyle}" Click="PreviousWeek_Click"/>
                            <TextBlock x:Name="WeekText" 
                                       Text="Текущая неделя" 
                                       FontSize="13" 
                                       FontWeight="SemiBold"
                                       Foreground="#5271FF"
                                       VerticalAlignment="Center"
                                       Margin="15,0"/>
                            <Button Content="▶" Style="{StaticResource NavButtonStyle}" Click="NextWeek_Click"/>
                        </StackPanel>
                    </Border>

                    <Button Content="📅 Сегодня" 
                            Style="{StaticResource PrimaryButton}"
                            Click="TodayButton_Click"/>
                    <Button Content="🔄 Обновить" 
                            Style="{StaticResource SecondaryButton}"
                            Click="Refresh_Click"
                            Margin="10,0,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Таблица расписания -->
        <Border Grid.Row="1" 
                Background="White" 
                BorderBrush="#E0E0E0" 
                BorderThickness="1"
                CornerRadius="8"
                Margin="30,20,30,20">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                <Grid x:Name="ScheduleGrid">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="50"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Заголовки столбцов -->
                    <Border Grid.Row="0" Grid.Column="0" Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="0,0,1,1">
                        <TextBlock Text="Время" Style="{StaticResource DayHeaderStyle}"/>
                    </Border>

                    <Border Grid.Row="0" Grid.Column="1" Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="0,0,1,1">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="Понедельник" Style="{StaticResource DayHeaderStyle}"/>
                            <TextBlock x:Name="MondayDate" FontSize="11" Foreground="#999" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="0" Grid.Column="2" Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="0,0,1,1">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="Вторник" Style="{StaticResource DayHeaderStyle}"/>
                            <TextBlock x:Name="TuesdayDate" FontSize="11" Foreground="#999" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="0" Grid.Column="3" Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="0,0,1,1">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="Среда" Style="{StaticResource DayHeaderStyle}"/>
                            <TextBlock x:Name="WednesdayDate" FontSize="11" Foreground="#999" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="0" Grid.Column="4" Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="0,0,1,1">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="Четверг" Style="{StaticResource DayHeaderStyle}"/>
                            <TextBlock x:Name="ThursdayDate" FontSize="11" Foreground="#999" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="0" Grid.Column="5" Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="0,0,1,1">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="Пятница" Style="{StaticResource DayHeaderStyle}"/>
                            <TextBlock x:Name="FridayDate" FontSize="11" Foreground="#999" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="0" Grid.Column="6" Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="0,0,1,1">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="Суббота" Style="{StaticResource DayHeaderStyle}"/>
                            <TextBlock x:Name="SaturdayDate" FontSize="11" Foreground="#999" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Время уроков (1-7 пара) -->
                    <Border Grid.Row="1" Grid.Column="0" Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="0,0,1,1">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="8:00" FontSize="12" FontWeight="SemiBold" Foreground="#333"/>
                            <TextBlock Text="9:30" FontSize="10" Foreground="#999"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="2" Grid.Column="0" Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="0,0,1,1">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="9:40" FontSize="12" FontWeight="SemiBold" Foreground="#333"/>
                            <TextBlock Text="11:10" FontSize="10" Foreground="#999"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="3" Grid.Column="0" Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="0,0,1,1">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="11:20" FontSize="12" FontWeight="SemiBold" Foreground="#333"/>
                            <TextBlock Text="12:50" FontSize="10" Foreground="#999"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="4" Grid.Column="0" Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="0,0,1,1">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="13:45" FontSize="12" FontWeight="SemiBold" Foreground="#333"/>
                            <TextBlock Text="15:15" FontSize="10" Foreground="#999"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="5" Grid.Column="0" Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="0,0,1,1">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="15:25" FontSize="12" FontWeight="SemiBold" Foreground="#333"/>
                            <TextBlock Text="16:55" FontSize="10" Foreground="#999"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="6" Grid.Column="0" Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="0,0,1,1">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="17:05" FontSize="12" FontWeight="SemiBold" Foreground="#333"/>
                            <TextBlock Text="18:35" FontSize="10" Foreground="#999"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="7" Grid.Column="0" Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="0,0,1,1">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="18:45" FontSize="12" FontWeight="SemiBold" Foreground="#333"/>
                            <TextBlock Text="20:15" FontSize="10" Foreground="#999"/>
                        </StackPanel>
                    </Border>

                    <!-- Ячейки для уроков (заполняются динамически) -->
                </Grid>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>