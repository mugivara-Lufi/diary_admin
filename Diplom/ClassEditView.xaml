<UserControl x:Class="Diplom.ClassEditView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Diplom"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="600">

    <UserControl.Resources>
        <!-- ... (оставляем стили без изменений) ... -->
    </UserControl.Resources>

    <Grid Background="#F8F9FA">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="30,20">
            <Grid>
                <StackPanel Orientation="Horizontal">
                    <Button Content="← " 
                            Style="{StaticResource TextButton}"
                            Click="BackButton_Click"
                            Padding="8"
                            Margin="0,0,10,0"/>
                    <StackPanel>
                        <TextBlock Text="{Binding TitleText, FallbackValue='Редактирование группы'}" 
                                   FontSize="22" 
                                   FontWeight="SemiBold" 
                                   Foreground="#333"/>
                        <TextBlock Text="{Binding SubtitleText, FallbackValue='Заполните информацию о группе'}" 
                                   FontSize="13" 
                                   Foreground="#999"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Форма редактирования -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Border Background="White" 
                    BorderBrush="#E0E0E0" 
                    BorderThickness="1"
                    CornerRadius="8"
                    Margin="30,20,30,20"
                    Padding="30">
                <StackPanel MaxWidth="600">

                    <!-- Основная информация -->
                    <TextBlock Text="🏫 Основная информация" 
                               FontSize="16" 
                               FontWeight="SemiBold" 
                               Foreground="#333"
                               Margin="0,0,0,20"/>

                    <!-- Название группы -->
                    <StackPanel Margin="0,0,0,20">
                        <TextBlock Style="{StaticResource FormLabel}">
                            <Run Text="Название группы"/>
                            <Run Text="*" Foreground="#E53E3E"/>
                        </TextBlock>
                        <TextBox x:Name="NameTextBox" 
                                 Style="{StaticResource FormTextBox}"
                                 Tag="Например: 9А, 11Б"
                                 Text="{Binding CurrentClass.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Text="Укажите номер и букву группы" 
                                   FontSize="12" 
                                   Foreground="#999"
                                   Margin="0,6,0,0"/>
                    </StackPanel>

                    <!-- Разделитель -->
                    <Border Height="1" Background="#E0E0E0" Margin="0,10,0,20"/>

                    <!-- Куратор группы -->
                    <StackPanel Margin="0,0,0,20">
                        <TextBlock Text="👨‍🏫 Куратор группы" 
                                   FontSize="16" 
                                   FontWeight="SemiBold" 
                                   Foreground="#333"
                                   Margin="0,0,0,15"/>

                        <TextBlock Text="Преподаватель" Style="{StaticResource FormLabel}"/>
                        <ComboBox x:Name="TeacherComboBox"
                                  Style="{StaticResource FormComboBox}"
                                  DisplayMemberPath="FullName"
                                  SelectedValuePath="Id"
                                  SelectedValue="{Binding CurrentClass.TeacherId, Mode=TwoWay}" Height="42"/>
                        <TextBlock Text="Выберите куратора группы из списка преподавателей" 
                                   FontSize="12" 
                                   Foreground="#999"
                                   Margin="0,6,0,0"/>
                    </StackPanel>

                    <!-- Разделитель -->
                    <Border Height="1" Background="#E0E0E0" Margin="0,10,0,20"/>

                    <!-- Информационная панель -->
                    <Border Background="#F5F7FF" 
                            Padding="20" 
                            CornerRadius="8">
                        <StackPanel>
                            <TextBlock Text="💡 Полезная информация" 
                                       FontSize="14" 
                                       FontWeight="SemiBold"
                                       Foreground="#5271FF"
                                       Margin="0,0,0,10"/>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="•" Foreground="#5271FF" Margin="0,0,8,0" FontSize="12"/>
                                <TextBlock Text="Название группы должно быть уникальным в системе" 
                                           FontSize="12" 
                                           Foreground="#666"
                                           TextWrapping="Wrap"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="•" Foreground="#5271FF" Margin="0,0,8,0" FontSize="12"/>
                                <TextBlock Text="Куратор группы может быть назначен позже" 
                                           FontSize="12" 
                                           Foreground="#666"
                                           TextWrapping="Wrap"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="•" Foreground="#5271FF" Margin="0,0,8,0" FontSize="12"/>
                                <TextBlock Text="После создания группы вы сможете добавить студентов" 
                                           FontSize="12" 
                                           Foreground="#666"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </ScrollViewer>

        <!-- Кнопки действий -->
        <Border Grid.Row="2" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Padding="30,15">
            <Grid>
                <TextBlock Text="* Обязательные поля" 
                           FontSize="12" 
                           Foreground="#999"
                           VerticalAlignment="Center"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Отмена" 
                            Style="{StaticResource SecondaryButton}" 
                            Click="CancelButton_Click"/>
                    <Button Content="💾 Сохранить" 
                            Style="{StaticResource PrimaryButton}" 
                            Click="SaveButton_Click"
                            Margin="10,0,0,0"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>