<UserControl x:Class="Diplom.ScheduleEditView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Diplom"
             mc:Ignorable="d" d:DesignWidth="600" Height="689">



    <Grid Background="#F8F9FA">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="30,20">
            <Grid>
                <StackPanel>
                    <TextBlock Text="{Binding TitleText}" 
                               FontSize="22" 
                               FontWeight="SemiBold" 
                               Foreground="#333"/>
                    <TextBlock Text="{Binding SubtitleText}" 
                               FontSize="13" 
                               Foreground="#999"
                               Margin="0,5,0,0"/>
                </StackPanel>

                <Button Content="← Назад" 
                        Style="{StaticResource SecondaryButton}" 
                        Click="BackButton_Click"
                        HorizontalAlignment="Right"/>
            </Grid>
        </Border>

        <!-- Форма -->
        <Border Grid.Row="1" 
                Background="White" 
                Margin="30,20"
                CornerRadius="8"
                BorderBrush="#E0E0E0" 
                BorderThickness="1">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="30">
                <StackPanel>

                    <!-- Класс -->
                    <StackPanel x:Name="ClassInfoPanel" Margin="0,0,0,20">
                        <TextBlock Text="Класс" 
                                   FontSize="13" 
                                   FontWeight="SemiBold"
                                   Foreground="#333"
                                   Margin="0,0,0,8"/>
                        <TextBlock x:Name="ClassNameText"
                                   FontSize="13" 
                                   Foreground="#666"
                                   Padding="12,10"/>
                        <TextBlock Text="Урок будет добавлен для выбранного класса" 
                                   FontSize="11" 
                                   Foreground="#999"
                                   Margin="0,5,0,0"/>
                    </StackPanel>

                    <!-- Предмет -->
                    <StackPanel Margin="0,0,0,20">
                        <TextBlock Text="Предмет *" 
                                   FontSize="13" 
                                   FontWeight="SemiBold"
                                   Foreground="#333"
                                   Margin="0,0,0,8"/>
                        <ComboBox x:Name="SubjectComboBox"
                                  Style="{StaticResource FormComboBox}"
                                  DisplayMemberPath="Name"
                                  SelectedValuePath="Id"
                                  SelectionChanged="SubjectComboBox_SelectionChanged" Height="40"/>
                    </StackPanel>

                    <!-- Учитель -->
                    <StackPanel Margin="0,0,0,20">
                        <TextBlock Text="Учитель *" 
                                   FontSize="13" 
                                   FontWeight="SemiBold"
                                   Foreground="#333"
                                   Margin="0,0,0,8"/>
                        <ComboBox x:Name="TeacherComboBox"
                                  Style="{StaticResource FormComboBox}"
                                  DisplayMemberPath="FullName"
                                  SelectedValuePath="Id"
                                  SelectionChanged="TeacherComboBox_SelectionChanged" Height="40"/>
                        <TextBlock Text="Выберите учителя, который ведет этот предмет" 
                                   FontSize="11" 
                                   Foreground="#999"
                                   Margin="0,5,0,0"/>
                    </StackPanel>

                    <!-- Дата урока -->
                    <StackPanel Margin="0,0,0,20">
                        <TextBlock Text="Дата урока *" 
                                   FontSize="13" 
                                   FontWeight="SemiBold"
                                   Foreground="#333"
                                   Margin="0,0,0,8"/>
                        <DatePicker x:Name="LessonDatePicker"
            Style="{StaticResource FormDatePicker}"
            SelectedDate="{Binding CurrentSchedule.LessonDate, Mode=TwoWay}"
            SelectedDateChanged="LessonDatePicker_SelectedDateChanged"/>


                    </StackPanel>

                    <!-- Номер урока -->
                    <StackPanel Margin="0,0,0,20">
                        <TextBlock Text="Номер урока *" 
                                   FontSize="13" 
                                   FontWeight="SemiBold"
                                   Foreground="#333"
                                   Margin="0,0,0,8"/>
                        <ComboBox x:Name="LessonNumberComboBox"
                                  Style="{StaticResource FormComboBox}"
                                  DisplayMemberPath="Value"
                                  SelectedValuePath="Key"
                                  SelectionChanged="LessonNumberComboBox_SelectionChanged" Height="40"/>
                        <TextBlock Text="Выберите порядковый номер урока в расписании" 
                                   FontSize="11" 
                                   Foreground="#999"
                                   Margin="0,5,0,0"/>
                    </StackPanel>

                    <!-- Тема -->
                    <StackPanel Margin="0,0,0,20">
                        <TextBlock Text="Тема урока" 
                                   FontSize="13" 
                                   FontWeight="SemiBold"
                                   Foreground="#333"
                                   Margin="0,0,0,8"/>
                        <TextBox x:Name="TopicTextBox" 
                                 Style="{StaticResource FormTextBox}"
                                 Text="{Binding CurrentSchedule.Topic, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Height="60"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"/>
                        <TextBlock Text="Необязательное поле. Можно указать тему занятия" 
                                   FontSize="11" 
                                   Foreground="#999"
                                   Margin="0,5,0,0"/>
                    </StackPanel>

                    <!-- Время -->
                    <Border Background="#F5F7FF" 
                            Padding="15" 
                            CornerRadius="6"
                            Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="🕐 Время урока" 
                                       FontSize="13" 
                                       FontWeight="SemiBold"
                                       Foreground="#5271FF"
                                       Margin="0,0,0,5"/>
                            <TextBlock x:Name="TimeInfoText"
                                       FontSize="11" 
                                       Foreground="#666"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- Конфликты -->
                    <Border x:Name="ConflictWarningPanel"
                            Background="#FEF2F2" 
                            Padding="15" 
                            CornerRadius="6"
                            Margin="0,0,0,20"
                            Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text="⚠️ Возможный конфликт" 
                                       FontSize="13" 
                                       FontWeight="SemiBold"
                                       Foreground="#DC2626"
                                       Margin="0,0,0,5"/>
                            <TextBlock x:Name="ConflictWarningText"
                                       FontSize="11" 
                                       Foreground="#DC2626"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Кнопки -->
        <Border Grid.Row="2" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Padding="30,20">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="❌ Отмена" 
                        Style="{StaticResource SecondaryButton}" 
                        Click="CancelButton_Click"/>
                <Button Content="💾 Сохранить" 
                        Style="{StaticResource PrimaryButton}" 
                        Click="SaveButton_Click"
                        Margin="10,0,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
